#!/usr/bin/env -S emacs -x
;; -*- lexical-binding: t; -*-

;; Copyright (C) 2025 Mekeor Melire

;; This file is NOT part of GNU Emacs.

;; This code is licensed under GNU General Public License version 3,
;; see LICENSE.GPL3.

;;; Commentary:

;; This file generates Emacs-Lisp files based on data from Lean4
;; plugin for VS-Code.

;;; Code:

;;;; Fetch Upstream Abbreviations

(defconst b-abbrev-alist
  (with-temp-buffer
    (url-insert-file-contents
     (concat "https://raw.githubusercontent.com"
             "/leanprover/vscode-lean4/refs/heads/master"
             "/lean4-unicode-input/src/abbreviations.json"))
    (goto-char (point-min))
    (let ((json-key-type 'string))
      (json-read)))
  "Raw abbreviations alist mapping strings to strings.

Keys may include `$CURSOR'.")

(defconst b-abbrev-separator
  (regexp-quote "$CURSOR"))

(defconst b-abbrev-inseparable
  (seq-remove (lambda (pair) (string-match-p b-abbrev-separator (cdr pair)))
              b-abbrev-alist))

(defconst b-abbrev-separable
  (mapcan (pcase-lambda (`(,abbrev . ,expans))
            (when-let* ((split (string-split expans b-abbrev-separator))
                        ((not (length= split 1))))
              (list (cons abbrev (cons (car split) (cadr split))))))
          b-abbrev-alist))

;;;; Generate `nael-abbrev.el'

(with-temp-file "nael/nael-abbrev.el"
  (insert
   ";;; nael-abbrev.el --- Abbrev for Nael  -*- lexical-binding: t; -*-"
   "\n"
   "\n;; Copyright (C) 2025 Mekeor Melire"
   "\n"
   "\n;; This file is NOT part of GNU Emacs."
   "\n"
   "\n;; This code is licensed under GNU General Public License version 3,"
   "\n;; see LICENSE.GPL3."
   "\n"
   "\n;;; Commentary:"
   "\n"
   "\n;; This file has been generated by `generate.el' by relying on data"
   "\n;; from the Lean4 plugin for VS-Code.  It defines `nael-abbrev-table'"
   "\n;; for conveniently inserting Unicode characters that are common in"
   "\n;; Lean4 code.  For more information on Emacs' Abbrev feature, consult"
   "\n;; the docstrings of `abbrev-mode' and `local-abbrev-table' and the"
   "\n;; corresponding Info manual (info \"(emacs) Abbrevs\")."
   "\n"
   "\n;;; Code:"
   "\n"
   "\n(define-abbrev-table 'nael-abbrev-table")
  (let ((max (1- (length b-abbrev-inseparable))))
    (seq-do-indexed
     (lambda (pair index)
       (insert (format "\n%s%S %S nil :system t%s"
                       (if (eq 0 index) "  '((" "    (")
                       (concat "\\" (car pair))
                       (cdr pair)
                       (if (eq max index) ")))" ")"))))
     b-abbrev-inseparable))
  (insert
   "\n"
   "\n(provide 'nael-abbrev)"
   "\n"
   "\n;;; nael-abbrev.el ends here"))

;;;; Generate `neal-skeleton.el'

(with-temp-file "nael/nael-skeleton.el"
  (insert
   ";;; nael-skeleton.el --- Skeleton for Nael  -*- lexical-binding: t; -*-"
   "\n"
   "\n;; Copyright (C) 2025 Mekeor Melire"
   "\n"
   "\n;; This file is NOT part of GNU Emacs."
   "\n"
   "\n;; This code is licensed under GNU General Public License version 3,"
   "\n;; see LICENSE.GPL3."
   "\n"
   "\n;;; Commentary:"
   "\n"
   "\n;; TODO"
   "\n"
   "\n;;; Code:"
   "\n"
   "\n(require 'skeleton)"
   "\n")
  (let ((max (1- (length b-abbrev-separable))))
    (seq-do-indexed
     (lambda (pair index)
       (insert "\n(define-skeleton nael-skeleton-")
       (dolist (char (append (string-to-list (cadr pair))
                             (string-to-list (cddr pair))))
         (insert (format "%x" char)))
       (insert
        " nil nil"
        (format " %S _ %S" (cadr pair) (cddr pair))
        ")"))
     b-abbrev-separable))
  (insert
   "\n"
   "\n(provide 'nael-skeleton)"
   "\n"
   "\n;;; nael-skeleton.el ends here"))

