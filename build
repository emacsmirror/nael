#!/usr/bin/env -S emacs -x
;; -*- lexical-binding: t; -*-

;; Copyright (C) 2025 Mekeor Melire

;; This file is NOT part of GNU Emacs.

;; This code is licensed under GNU General Public License version 3,
;; see LICENSE.GPL3.

;;; Commentary:

;; This file generates Emacs-Lisp source files based on data from the
;; official Lean plugin for another editor.

;; For editing the strings that include Elisp code, it's best to
;; install the package `separedit', then type C-u M-x separedit-dwim
;; RET emacs-lisp-mode RET.

;;; Code:

;;;; Fetch Upstream Abbreviations

(defconst build-abbrev-alist
  (with-temp-buffer
    (url-insert-file-contents
     (concat "https://raw.githubusercontent.com"
             "/leanprover/vscode-lean4/refs/heads/master"
             "/lean4-unicode-input/src/abbreviations.json"))
    (goto-char (point-min))
    (let ((json-key-type 'string))
      (json-read)))
  "Raw abbreviations alist mapping strings to strings.

Keys may include `$CURSOR'.")

(defconst build-abbrev-separator
  (regexp-quote "$CURSOR"))

(defconst build-abbrev-singletons
  (seq-remove (lambda (pair)
                (string-match-p build-abbrev-separator (cdr pair)))
              build-abbrev-alist))

(defconst build-abbrev-skeletons
  (mapcan
   (pcase-lambda (`(,abbrev . ,expans))
     (when-let*
         ((expans (string-split expans build-abbrev-separator))
          ((not (length= expans 1))))
       (list (list abbrev (car expans) (cadr expans)
                   (concat "nael-skeleton-"
                           (mapconcat (apply-partially #'format "%x")
                                      abbrev))))))
   build-abbrev-alist))

(defconst build-abbrev-table-regexp
  ;; The regexp for characters that might be part of abbreviations, in
  ;; addition to word constituents, is "[][)(}{><|-]".  That's because
  ;; `]' has to be at the beginning, and `-' has to be at the end of
  ;; bracket expressions; see (info "(elisp) Regexp Special").
  "\\(\\\\[][)(}{><|[:word:]-]+\\)")

;;;; Generate `nael-abbrev.el'

(with-temp-file "nael/nael-abbrev.el"
  (insert
   (format
    ";;; nael-abbrev.el --- Abbrev for Nael  -*- lexical-binding: t; -*-

;; Copyright (C) 2025 Mekeor Melire

;; This file is NOT part of GNU Emacs.

;; This code is licensed under GNU General Public License version 3,
;; see LICENSE.GPL3.

;;; Commentary:

;; This file has been generated by `build' by relying on data from the
;; official Lean plugin for another editor.  Please do not edit this
;; file directly; edit `build' instead!

;; This file defines Abbrev tables for conveniently inserting Unicode
;; characters that are common in Lean code.  For more information on
;; Emacs' Abbrev feature, consult the docstrings of `abbrev-mode' and
;; `local-abbrev-table' and the corresponding Info manual:
;;
;;   (info \"(emacs) Abbrevs\")

;; The abbreviations introduced here can be classified into two
;; disjunct sets:
;;
;;   1. /Singleton/ abbreviations expand to single strings.  During
;;      expansion, point is reserved at the end of expansion.
;;
;;   2. /Skeleton/ abbreviations expand to two strings with point
;;      being placed between the left and the right part.  The name is
;;      derived from `skeleton', a built-in Emacs package used to
;;      implement this class of abbreviations.
;;
;; As a consequence, this file defines three Abbrev tables.
;; `nael-abbrev-table-only-singletons' and
;; `nael-abbrev-table-only-skeletons' have self-explaining names.  The
;; recommended Abbrev table for `nael-mode' is `nael-abbrev-table'
;; which inherits elements from both aforementioned Abbrev tables.

;; One crucial challenge in the development of this file was that
;; `abbrev-mode' was originally designed for abbreviations that
;; exclusively consist of word-constituent characters.  Whereas in
;; Lean, we desire abbreviations like \\f<<>>.  One measure we need to
;; take for this requirement is to specify `:regexp' properties for
;; our Abbrev tables; see (info \"(elisp) Abbrev Table Properties\").
;; This already works fine when calling `expand-abbrev' explicitly.
;; But at the time of writing (August 2025), `self-insert-command'
;; rules out automatic expansion of abbreviations that end in
;; non-word-constituent characters.  As a workaround, you can call
;; function `nael-init-abbrev'.  It will add `nael-abbrev-expand' to
;; the `post-self-insert-hook' which considers expansion for a
;; suitably wider range of characters.

;;; Code:

(require 'abbrev)

(require 'nael-skeleton)

;;;###autoload
(defun nael-abbrev-expand ()
  \"Expand symbol-including abbreviation before point.\"
  (and abbrev-mode
       (string-match-p %S
                       (char-to-string last-command-event))
       (let ((pt (point))) (backward-char)
            (unless (expand-abbrev)
              (goto-char pt)))))

(defun nael-abbrev-config ()
  \"Configure `abbrev-mode' for `nael-mode'.

Buffer-locally sets `local-abbrev-table' and adds `nael-abbrev-expand'
to `post-self-insert-hook' so that symbol-including abbreviations are
expanded whenever suitable characters are inserted.\"
  (setq-local local-abbrev-table nael-abbrev-table)
  (add-hook 'post-self-insert-hook #'nael-abbrev-expand nil t))

(define-abbrev-table 'nael-abbrev-table-only-singletons
  %s
  \"Abbrev table with singleton abbreviations for `nael-mode'.

All abbreviations expand to single strings.  During expansion, point is
reserved at the end of expansion.\"
  :regexp %S)

(define-abbrev-table 'nael-abbrev-table-only-skeletons
  %s
  \"Abbrev table with Skeleton abbreviations for `nael-mode'.

All abbreviations expand to two strings with point being placed between
the left and the right part.  The name is derived from `skeleton', a
built-in Emacs package used to implement this class of abbreviations.\"
  :regexp %S)

(define-abbrev-table 'nael-abbrev-table
  nil
\"Abbrev table for `nael-mode'.

It includes both singleton abbreviations that expand to single strings,
as well as Skeleton abbreviations that expand to two strings, with point
being placed between the left and the right part.\"
  :regexp %S
  :parents (list nael-abbrev-table-only-singletons
                 nael-abbrev-table-only-skeletons))

(provide 'nael-abbrev)

;;; nael-abbrev.el ends here

;; Local Variables:
;; buffer-read-only: t
;; End:
"
    "[^][)(}{><|[:word:]-]"
    (let ((max (1- (length build-abbrev-singletons))))
      (string-join
       (seq-map-indexed
        (lambda (pair index)
          (format "%s%S %S nil :system t%s"
                  (if (eq 0 index) "'((" "    (")
                  (concat "\\" (car pair))
                  (cdr pair)
                  (if (eq max index) "))" ")")))
        build-abbrev-singletons)
      "\n"))
    build-abbrev-table-regexp
    (let ((max (1- (length build-abbrev-skeletons))))
      (string-join
       (seq-map-indexed
        (pcase-lambda (`(,abbrev ,expl ,expr ,name) index)
          (format "%s%S \"\" %s :system t%s"
                  (if (eq 0 index) "'((" "    (")
                  (concat "\\" abbrev)
                  name
                  (if (eq max index) "))" ")")))
        build-abbrev-skeletons)
       "\n"))
    build-abbrev-table-regexp
    build-abbrev-table-regexp)))

;;;; Generate `neal-skeleton.el'

(with-temp-file "nael/nael-skeleton.el"
  (insert
   (format
    ";;; nael-skeleton.el --- Skeleton for Nael  -*- lexical-binding: t; -*-

;; Copyright (C) 2025 Mekeor Melire

;; This file is NOT part of GNU Emacs.

;; This code is licensed under GNU General Public License version 3,
;; see LICENSE.GPL3.

;;; Commentary:

;; This file has been generated by `build' by relying on data from the
;; official Lean plugin for another editor.  Please do not edit this
;; file directly; edit `build' instead!

;; This file defines Skeleton templates for abbreviations that expand
;; to two strings, with point being placed between the left and the
;; right part.  For more information on Emacs' built-in `skeleton'
;; package, see consult its Info manual:
;;
;;   (info \"(autotype) Top\")

;; Note that `nael-abbrev' defines Abbrev tables built on top of these
;; Skeleton templates, as described at:
;;
;;   (info \"(autotype) Skeletons as Abbrevs\")

;;; Code:

(require 'skeleton)

%s

(provide 'nael-skeleton)

;;; nael-skeleton.el ends here

;; Local Variables:
;; buffer-read-only: t
;; End:
"
    (let ((max (1- (length build-abbrev-skeletons))))
      (string-join
       (seq-map-indexed
        (pcase-lambda (`(,abbrev ,left ,right ,name) index)
          (format
           "(define-skeleton %s \"\" nil %S _ %S)"
           name left right))
        build-abbrev-skeletons)
       "\n")))))

;;;; Generate `**/*-autoloads.el'

(dolist (dir (file-expand-wildcards "nael*"))
  (message dir)
  (loaddefs-generate
   dir
   (file-name-concat dir (concat dir "-autoloads.el"))))

;;; build ends here
