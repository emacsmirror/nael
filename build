#!/usr/bin/env -S emacs -x
;; -*- lexical-binding: t; -*-

;; Copyright (C) 2025 Mekeor Melire

;; This file is NOT part of GNU Emacs.

;; This code is licensed under GNU General Public License version 3,
;; see LICENSE.GPL3.

;;; Commentary:

;; This file generates Emacs-Lisp files based on data from Lean4 plugin for
;; VS-Code.  For editing the strings that include Elisp code, I recommend
;; installing the package `separedit', then typing C-u M-x separedit-dwim RET
;; emacs-lisp-mode RET.

;;; Code:

;;;; Fetch Upstream Abbreviations

(defconst build-abbrev-alist
  (with-temp-buffer
    (url-insert-file-contents
     (concat "https://raw.githubusercontent.com"
             "/leanprover/vscode-lean4/refs/heads/master"
             "/lean4-unicode-input/src/abbreviations.json"))
    (goto-char (point-min))
    (let ((json-key-type 'string))
      (json-read)))
  "Raw abbreviations alist mapping strings to strings.

Keys may include `$CURSOR'.")

(defconst build-abbrev-separator
  (regexp-quote "$CURSOR"))

(defconst build-abbrev-inseparable
  (seq-remove (lambda (pair) (string-match-p build-abbrev-separator (cdr pair)))
              build-abbrev-alist))

(defconst build-abbrev-separable
  (mapcan (pcase-lambda (`(,abbrev . ,expans))
            (when-let* ((expans (string-split expans build-abbrev-separator))
                        ((not (length= expans 1)))
                        (expl (car expans))
                        (expr (cadr expans))
                        (expans (string-to-list (concat expl expr))))
              (list (list abbrev expl expr
                          (concat "nael-skeleton-"
                                  (mapconcat (apply-partially #'format "%x")
                                             abbrev))))))
          build-abbrev-alist))

(defconst build-abbrev-table-regexp "\\(\\\\.*\\)")

;;;; Generate `nael-abbrev.el'

(with-temp-file "nael/nael-abbrev.el"
  (insert
   (format
    ";;; nael-abbrev.el --- Abbrev for Nael  -*- lexical-binding: t; -*-

;; Copyright (C) 2025 Mekeor Melire

;; This file is NOT part of GNU Emacs.

;; This code is licensed under GNU General Public License version 3,
;; see LICENSE.GPL3.

;;; Commentary:

;; This file has been generated by `generate.el' by relying on data
;; from the Lean4 plugin for VS-Code.  It defines `nael-abbrev-table'
;; for conveniently inserting Unicode characters that are common in
;; Lean4 code.  For more information on Emacs' Abbrev feature, consult
;; the docstrings of `abbrev-mode' and `local-abbrev-table' and the
;; corresponding Info manual (info \"(emacs) Abbrevs\").

;;; Code:

(require 'abbrev)

(require 'nael-skeleton)

(defun nael-abbrev-expand ()
  \"Expand abbreviations that don't only consist of word constituents.\")

(define-abbrev-table 'nael-abbrev-table-without-skeletons
  %s
  :regexp %S)

(define-abbrev-table 'nael-abbrev-table-only-skeletons
  %s
  :regexp %S)

(define-abbrev-table 'nael-abbrev-table
  nil
  :regexp %S
  :parents (list nael-abbrev-table-without-skeletons
                 nael-abbrev-table-only-skeletons))

(provide 'nael-abbrev)

;;; nael-abbrev.el ends here"
    (let ((max (1- (length build-abbrev-inseparable))))
      (string-join
       (seq-map-indexed
        (lambda (pair index)
          (format "%s%S %S nil :system t%s"
                  (if (eq 0 index) "'((" "    (")
                  (concat "\\" (car pair))
                  (cdr pair)
                  (if (eq max index) "))" ")")))
        build-abbrev-inseparable)
      "\n"))
    build-abbrev-table-regexp
    (let ((max (1- (length build-abbrev-separable))))
      (string-join
       (seq-map-indexed
        (pcase-lambda (`(,abbrev ,expl ,expr ,name) index)
          (format "%s%S \"\" %s :system t%s"
                  (if (eq 0 index) "'((" "    (")
                  (concat "\\" abbrev)
                  name
                  (if (eq max index) "))" ")")))
        build-abbrev-separable)
       "\n"))
    build-abbrev-table-regexp
    build-abbrev-table-regexp)))

;;;; Generate `neal-skeleton.el'

(with-temp-file "nael/nael-skeleton.el"
  (insert
   (format
    ";;; nael-skeleton.el --- Skeleton for Nael  -*- lexical-binding: t; -*-

;; Copyright (C) 2025 Mekeor Melire

;; This file is NOT part of GNU Emacs.

;; This code is licensed under GNU General Public License version 3,
;; see LICENSE.GPL3.

;;; Commentary:

;; TODO

;;; Code:

(require 'skeleton)

%s

(provide 'nael-skeleton)

;;; nael-skeleton.el ends here"
    (let ((max (1- (length build-abbrev-separable))))
      (string-join
       (seq-map-indexed
        (pcase-lambda (`(,abbrev ,left ,right ,name) index)
          (format
           "(define-skeleton %s \"\" nil %S _ %S)"
           name left right))
        build-abbrev-separable)
       "\n")))))
